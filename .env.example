# Copy to `.env` and point at your server.
#
# Production (deployed Cloudflare Worker):
# EXPO_PUBLIC_SERVER_URL=https://team-taboo-araby.<your-subdomain>.workers.dev
#
# LAN development — run `wrangler dev --ip 0.0.0.0` in the web repo, then use
# your computer's LAN IP here (NOT localhost; on a phone that resolves to the
# phone itself):
# EXPO_PUBLIC_SERVER_URL=http://192.168.1.20:8787
